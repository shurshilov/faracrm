# ────────────────────────────────────────────────────────────────
# Reverse-proxy для FARA CRM
# По образцу fara_landing/nginx.conf, адаптировано под две цели:
#   /api/* → backend (со снятием префикса)
#   /     → frontend
# Шаблон. Реальный конфиг генерируется скриптом init-letsencrypt.sh
# в nginx/conf.d/fara.conf на основе .env
# ────────────────────────────────────────────────────────────────

# DNS-резолвер встроенный в Docker (127.0.0.11). Нужен, потому что в
# location ~ ^/api/(.*)$ proxy_pass содержит переменную $1, и nginx
# переключается в runtime-резолвинг — без resolver падает с ошибкой
# "no resolver defined to resolve backend" → 502.
resolver 127.0.0.11 valid=10s ipv6=off;

# Поддержка WebSocket: если клиент шлёт Upgrade — пробрасываем upgrade,
# иначе оставляем стандартный keep-alive. Без этого map обычные HTTP-
# запросы получают пустой Connection и backend часто отвечает 502.
map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

server {
    listen 80;
    server_name ${SERVER_NAMES};

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl;
    http2 on;
    server_name ${SERVER_NAMES};

    ssl_certificate     /etc/letsencrypt/live/${DOMAIN}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/${DOMAIN}/privkey.pem;

    # Лимит на загрузку файлов (договоры, сканы)
    client_max_body_size 100m;

    # Длинные таймауты для отчётов и импорта
    proxy_read_timeout    300s;
    proxy_connect_timeout 30s;
    proxy_send_timeout    300s;

    # Прячем заголовки безопасности от внутреннего nginx во frontend-образе,
    # чтобы не было дублей с нашими.
    proxy_hide_header X-Frame-Options;
    proxy_hide_header X-Content-Type-Options;
    proxy_hide_header Content-Security-Policy;
    proxy_hide_header Referrer-Policy;

    # ── /api/* → backend (со снятием префикса) ─────────────────────
    # FastAPI публикует роуты без /api префикса (/signin, /sessions/, ...).
    # Фронт клеит /api/ через baseQuery.baseUrl — здесь его снимаем.
    location ~ ^/api/(.*)$ {
        # Хост в переменной — чтобы корректно работал runtime-resolver выше.
        set $backend_upstream "backend:8000";
        proxy_pass http://$backend_upstream/$1$is_args$args;

        proxy_http_version 1.1;

        # WebSocket — Upgrade/Connection через map, см. наверху файла
        proxy_set_header Upgrade           $http_upgrade;
        proxy_set_header Connection        $connection_upgrade;

        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # ── / → frontend (всё остальное, включая SPA-роутинг) ──────────
    location / {
        proxy_pass http://frontend:80;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # ── Security headers ───────────────────────────────────────────
    # CSP в одну строку — HTTP/2 запрещает переносы внутри значений.
    add_header Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: blob: https:; connect-src 'self' wss://$host; font-src 'self' data: https://fonts.gstatic.com; media-src 'self' blob:; object-src 'none'; frame-ancestors 'none'; base-uri 'self'; form-action 'self';" always;

    add_header X-Content-Type-Options "nosniff"                       always;
    add_header X-Frame-Options        "DENY"                          always;
    add_header Referrer-Policy        "strict-origin-when-cross-origin" always;

    # HSTS — раскомментировать через 1-2 недели стабильной работы
    # add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
}
