# ─────────────────────────────────────────────────────────────────
# Конфигурация деплоя FARA CRM.
# Скопируй этот файл в .env и поправь под свой домен/сервер:
#     cp .env.example .env
#     nano .env
# ─────────────────────────────────────────────────────────────────

# Домен сайта.
# Если домен кириллический — обязательно используй punycode (ASCII).
# Перевести можно командой:
#   python3 -c "print('мойдомен.рф'.encode('idna').decode())"
# Получится что-то вроде: xn--d1acklchcc.xn--p1ai
DOMAIN=example.com

# Дополнительный домен (обычно www-вариант основного).
# Если он не нужен — оставь пустым: WWW_DOMAIN=
WWW_DOMAIN=www.example.com

# Email для Let's Encrypt — на него будут приходить предупреждения
# об истечении сертификата (за 30, 14, 7 дней).
EMAIL=admin@example.com

# Имя docker-сети основного композа FARA.
# Compose берёт его как <имя_папки_проекта>_default.
# Если репозиторий лежит в /opt/faracrm/ — сеть будет faracrm_default.
FARA_NETWORK=faracrm_default

# Использовать staging-сертификат для отладки?
# 0 — боевой Let's Encrypt (по умолчанию)
# 1 — staging (сертификат не валиден в браузере, но не съедает rate limit
#     боевого окружения: 5 неудач в час).
STAGING=0
