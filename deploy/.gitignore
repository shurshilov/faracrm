# ─────────────────────────────────────────────────────────────────
# deploy/.gitignore
#
# Сертификаты и приватные ключи Let's Encrypt НИКОГДА не должны
# попадать в git. privkey.pem — это, по сути, доступ выписать
# поддельный TLS на твой домен.
# ─────────────────────────────────────────────────────────────────

# Сертификаты certbot (всё кроме .gitkeep)
proxy/certbot/conf/*
!proxy/certbot/conf/.gitkeep

proxy/certbot/www/*
!proxy/certbot/www/.gitkeep

# Сгенерированный nginx-конфиг (рендерится из templates/ при запуске).
# В git коммитим только шаблон, а не результат рендеринга — иначе там
# окажется чужой домен.
proxy/nginx/conf.d/*
!proxy/nginx/conf.d/.gitkeep

# .env файлы — содержат email, домен и потенциально другие настройки.
# В git коммитится только .env.example.
proxy/.env

# Логи и бэкапы
*.log
*.bak
*.backup
